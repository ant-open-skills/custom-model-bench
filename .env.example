# Copy to `.env` and fill in. Only providers you actually benchmark need keys —
# the kit gracefully skips candidates whose key is missing.

# --- LLM provider keys (Vercel AI SDK adapters) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
XAI_API_KEY=xai-...

# --- Tool API keys (only the agentic scopes use these) ---
# GitHub: read-only public-data lookups via api.github.com.
# A token raises rate limits and is needed for any private-org research.
GITHUB_TOKEN=ghp_...

# Proxycurl: LinkedIn profile enrichment for the Prospect qualifier.
# Without this, linkedin_enrich returns an error object the agent can fall
# back from to web_fetch — measurable but degraded behaviour.
PROXYCURL_API_KEY=...

# --- Cost-control env flags (set per-run, not in .env, but documented here) ---
# MOCK_TOOLS=1         — use deterministic fixtures instead of real APIs
# SKIP_JUDGE=1         — skip the 3-run Opus 4.7 judge (Stage 2 pipelines)
# SKIP_GROUNDING=1     — skip the Sonnet claim extractor (Stage 2 pipelines)
