{
  "name": "custom-model-bench",
  "version": "0.1.0",
  "private": true,
  "description": "Benchmark custom Claude agents and prompted workflows against datasets and rubrics.",
  "license": "MIT",
  "type": "module",
  "author": "Hendrik Krack",
  "scripts": {
    "bench:anthropic": "bun run skills/custom-model-bench/scripts/run-eval.ts skills/custom-model-bench/examples/demo",
    "bench:openai": "bun run skills/custom-model-bench/scripts/run-eval.ts skills/custom-model-bench/examples/demo config-openai.ts",
    "bench:google": "bun run skills/custom-model-bench/scripts/run-eval.ts skills/custom-model-bench/examples/demo config-google.ts",
    "bench:xai": "bun run skills/custom-model-bench/scripts/run-eval.ts skills/custom-model-bench/examples/demo config-xai.ts",
    "bench:all": "bun bench:anthropic && bun bench:openai && bun bench:google && bun bench:xai",
    "bench:compare": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/demo",
    "bench:tiers:anthropic": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/anthropic-tiers",
    "bench:tiers:openai": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/openai-tiers",
    "bench:tiers:google": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/google-tiers",
    "bench:tiers:xai": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/xai-tiers",
    "bench:tiers:all": "bun bench:tiers:anthropic && bun bench:tiers:openai && bun bench:tiers:google && bun bench:tiers:xai",
    "bench:reasoning": "bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/reasoning",
    "bench:tools": "MOCK_TOOLS=1 bun run skills/custom-model-bench/scripts/run-comparison.ts skills/custom-model-bench/examples/tool-bench",
    "bench:yc-qualifier": "MOCK_TOOLS=1 bun run skills/custom-model-bench/scripts/run-eval.ts skills/custom-model-bench/examples/yc-qualifier config-stage1.ts",
    "viewer:build": "bun run viewer/build-data.ts",
    "viewer:serve": "bun run viewer/serve.ts",
    "viewer": "bun viewer:build && bun viewer:serve",
    "viewer-v2:build": "bun run viewer-v2/build-data.ts",
    "viewer-v2:serve": "bun run viewer-v2/serve.ts",
    "viewer-v2": "bun viewer-v2:build && bun viewer-v2:serve"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/xai": "^3.0.83",
    "ai": "^6.0.168",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.6.3"
  }
}
